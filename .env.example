# ─────────────────────────────────────────────────────────
# Ortam Değişkenleri — Bu dosyayı .env olarak kopyalayın
# ve kendi değerlerinizi girin.
# ─────────────────────────────────────────────────────────

# Supabase Proje Ayarları
# https://supabase.com → Proje → Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-supabase-anon-key-here

# JWT Token Ayarları
# Güçlü bir secret key üretmek için: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
